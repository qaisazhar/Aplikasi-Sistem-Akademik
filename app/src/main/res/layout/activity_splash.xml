<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/splashContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/uap_primary"
    tools:context=".SplashActivity">
    <View
        android:id="@+id/circleTop"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:background="@drawable/circle_decoration_top"
        android:alpha="0.15"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="-80dp"
        android:layout_marginTop="-80dp"/>
    <View
        android:id="@+id/circleBottom"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/circle_decoration_bottom"
        android:alpha="0.15"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="-60dp"
        android:layout_marginBottom="-60dp"/>
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardLogo"
        android:layout_width="140dp"
        android:layout_height="140dp"
        app:cardCornerRadius="70dp"
        app:cardBackgroundColor="@color/uap_background"
        app:cardElevation="16dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.42">
        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_gravity="center"
            android:src="@drawable/logo_uap"
            android:contentDescription="Logo Universitas Aisyah Pringsewu"
            android:scaleType="fitCenter"
            android:padding="8dp"/>

    </com.google.android.material.card.MaterialCardView>
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aplikasi Akademik UAP"
        android:textColor="@color/uap_on_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="0.03"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/cardLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvUnivName"/>
    <TextView
        android:id="@+id/tvUnivName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Universitas Aisyah Pringsewu"
        android:textColor="@color/uap_secondary_light"
        android:textSize="13sp"
        android:letterSpacing="0.05"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/dividerLine"/>
    <View
        android:id="@+id/dividerLine"
        android:layout_width="60dp"
        android:layout_height="2dp"
        android:background="@color/uap_secondary_light"
        android:layout_marginTop="20dp"
        android:alpha="0.5"
        app:layout_constraintTop_toBottomOf="@id/tvUnivName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>
    <ProgressBar
        android:id="@+id/progressBar"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="120dp"
        android:layout_height="4dp"
        android:indeterminate="true"
        android:indeterminateTint="@color/uap_secondary_light"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/dividerLine"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0.0 © 2025 UAP"
        android:textColor="@color/uap_secondary_light"
        android:textSize="11sp"
        android:alpha="0.6"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
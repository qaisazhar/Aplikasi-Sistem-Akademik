<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="5dp"
    android:layout_marginBottom="5dp"
    app:cardCornerRadius="14dp"
    app:cardBackgroundColor="@color/uap_card_background"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">
        <androidx.cardview.widget.CardView
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:cardCornerRadius="18dp"
            app:cardBackgroundColor="@color/uap_surface_variant"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/tvNomor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/uap_primary"
                android:textSize="13sp"
                android:textStyle="bold"/>

        </androidx.cardview.widget.CardView>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">
            <TextView
                android:id="@+id/tvNamaMatkul"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mobile Programming"
                android:textColor="@color/uap_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tvKodeMatkul"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TI501"
                    android:textColor="@color/uap_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_badge_purple"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"/>

                <TextView
                    android:id="@+id/tvDosenMatkul"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ratnasari, S.Kom., M.Kom"
                    android:textColor="@color/uap_text_secondary"
                    android:textSize="11sp"
                    android:layout_marginStart="8dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:gravity="center_vertical"/>

            </LinearLayout>

        </LinearLayout>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/tvSks"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="3"
                android:textColor="@color/uap_on_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_sks_circle"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SKS"
                android:textColor="@color/uap_text_hint"
                android:textSize="10sp"
                android:gravity="center"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/uap_background_grey">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/uap_primary"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Info Pembayaran"
            android:textColor="@color/uap_on_primary"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detail Pembayaran Akademik"
            android:textColor="@color/uap_secondary_light"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>

    </LinearLayout>
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="4dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/uap_primary"
        app:cardElevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Tagihan Semester Ini"
                android:textColor="@color/uap_secondary_light"
                android:textSize="12sp"/>
            <TextView
                android:id="@+id/tvTotalTagihan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 3.500.000"
                android:textColor="@color/uap_on_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/uap_primary_variant"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sudah Dibayar"
                        android:textColor="@color/uap_secondary_light"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/tvSudahDibayar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 3.500.000"
                        android:textColor="@color/uap_gold"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sisa Tagihan"
                        android:textColor="@color/uap_secondary_light"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/tvSisaTagihan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textColor="#FF6B6B"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>
                <TextView
                    android:id="@+id/tvStatusLunas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LUNAS"
                    android:textColor="@color/uap_on_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_badge_count"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:layout_gravity="center_vertical"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBayarUkt"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="BAYAR UKT"
        android:textColor="@color/uap_on_primary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        app:backgroundTint="@color/uap_primary"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_payment"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconTint="@color/uap_on_primary"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Riwayat Pembayaran"
        android:textColor="@color/uap_text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"/>
    <ProgressBar
        android:id="@+id/progressPembayaran"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:indeterminate="true"
        android:visibility="gone"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPembayaran"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp"
        android:clipToPadding="false"
        android:scrollbars="none"/>

</LinearLayout>

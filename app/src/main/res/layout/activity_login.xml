<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/uap_background_grey"
    android:fillViewport="true"
    tools:context=".LoginActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:id="@+id/layoutHeader"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:background="@color/uap_primary"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="48dp"
            android:paddingBottom="40dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <androidx.cardview.widget.CardView
                android:layout_width="90dp"
                android:layout_height="90dp"
                app:cardCornerRadius="45dp"
                app:cardBackgroundColor="@color/uap_background"
                app:cardElevation="8dp">

                <ImageView
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:layout_gravity="center"
                    android:src="@drawable/logo_uap"
                    android:contentDescription="Logo UAP"
                    android:scaleType="fitCenter"
                    android:padding="6dp"/>

            </androidx.cardview.widget.CardView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aplikasi Akademik UAP"
                android:textColor="@color/uap_on_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="14dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Universitas Aisyah Pringsewu"
                android:textColor="@color/uap_secondary_light"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>
        <androidx.cardview.widget.CardView
            android:id="@+id/cardLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="-32dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/uap_card_background"
            app:cardElevation="12dp"
            app:layout_constraintTop_toBottomOf="@id/layoutHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Masuk Akun"
                    android:textColor="@color/uap_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Silakan login dengan NPM dan Password Anda"
                    android:textColor="@color/uap_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="24dp"/>
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilNpm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nomor Pokok Mahasiswa (NPM)"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/uap_border_focus"
                    app:hintTextColor="@color/uap_primary"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:startIconDrawable="@drawable/ic_person"
                    app:startIconTint="@color/uap_primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNpm"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLength="20"
                        android:textColor="@color/uap_text_primary"
                        android:textSize="14sp"
                        android:imeOptions="actionNext"/>

                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Password"
                    android:layout_marginTop="16dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/uap_border_focus"
                    app:hintTextColor="@color/uap_primary"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="@color/uap_primary"
                    app:passwordToggleEnabled="true"
                    app:passwordToggleTint="@color/uap_primary"
                    app:endIconMode="password_toggle">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/uap_text_primary"
                        android:textSize="14sp"
                        android:imeOptions="actionDone"/>

                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="MASUK"
                    android:textColor="@color/uap_on_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginTop="28dp"
                    app:backgroundTint="@color/uap_primary"
                    app:cornerRadius="12dp"
                    app:rippleColor="@color/uap_ripple_light"
                    app:icon="@drawable/ic_login"
                    app:iconTint="@color/uap_on_primary"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"/>
                <ProgressBar
                    android:id="@+id/progressLogin"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="12dp"
                    android:indeterminateTint="@color/uap_primary"
                    android:visibility="gone"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <TextView
            android:id="@+id/tvFooter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="© 2025 Universitas Aisyah Pringsewu"
            android:textColor="@color/uap_text_hint"
            android:textSize="11sp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            app:layout_constraintTop_toBottomOf="@id/cardLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
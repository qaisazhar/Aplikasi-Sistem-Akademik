<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="5dp"
    android:layout_marginBottom="5dp"
    app:cardCornerRadius="14dp"
    app:cardBackgroundColor="@color/uap_card_background"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <androidx.cardview.widget.CardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/uap_surface_variant"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/ivIconInfo"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_info"/>

            </androidx.cardview.widget.CardView>
            <TextView
                android:id="@+id/tvJudulInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Judul Informasi"
                android:textColor="@color/uap_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginStart="10dp"/>
            <View
                android:id="@+id/dotBaru"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_dot_red"
                android:layout_marginStart="6dp"/>

        </LinearLayout>
        <TextView
            android:id="@+id/tvIsiInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Isi konten informasi akademik ditampilkan di sini."
            android:textColor="@color/uap_text_secondary"
            android:textSize="12sp"
            android:maxLines="3"
            android:ellipsize="end"
            android:layout_marginTop="10dp"
            android:layout_marginStart="50dp"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp"
            android:layout_marginStart="50dp">
            <TextView
                android:id="@+id/tvKategoriInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Akademik"
                android:textColor="@color/uap_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_purple"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"/>
            <TextView
                android:id="@+id/tvTanggalInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="28 Mei 2025"
                android:textColor="@color/uap_text_hint"
                android:textSize="10sp"
                android:gravity="end"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/uap_background_grey"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <LinearLayout
            android:id="@+id/layoutHeader"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@color/uap_primary"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingBottom="40dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Profil Mahasiswa"
                android:textColor="@color/uap_on_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingTop="24dp"
                android:paddingBottom="16dp"/>

        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="-50dp">
            <androidx.cardview.widget.CardView
                android:id="@+id/cardFotoProfil"
                android:layout_width="100dp"
                android:layout_height="100dp"
                app:cardCornerRadius="50dp"
                app:cardBackgroundColor="@color/uap_secondary"
                app:cardElevation="8dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/ivFotoProfil"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="Foto profil"
                        android:scaleType="centerCrop"
                        android:visibility="gone"/>
                    <TextView
                        android:id="@+id/tvFotoInisial"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="BS"
                        android:textColor="@color/uap_on_primary"
                        android:textSize="32sp"
                        android:textStyle="bold"/>

                </FrameLayout>

            </androidx.cardview.widget.CardView>
            <TextView
                android:id="@+id/tvNamaProfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Budi Santoso"
                android:textColor="@color/uap_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"/>
            <TextView
                android:id="@+id/tvNpmProfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2210631170001"
                android:textColor="@color/uap_text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mahasiswa Aktif"
                android:textColor="@color/uap_success"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUbahFotoProfil"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Ubah Foto"
                android:textColor="@color/uap_on_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp"
                app:backgroundTint="@color/uap_primary"
                app:cornerRadius="20dp"
                app:icon="@drawable/ic_profile"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconTint="@color/uap_on_primary"/>

        </LinearLayout>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/uap_card_background"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATA AKADEMIK"
                    android:textColor="@color/uap_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp"/>
                <include layout="@layout/item_profil_row"
                    android:id="@+id/rowProdi"/>

                <View android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/uap_divider"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"/>
                <include layout="@layout/item_profil_row"
                    android:id="@+id/rowFakultas"/>

                <View android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/uap_divider"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"/>
                <include layout="@layout/item_profil_row"
                    android:id="@+id/rowSemester"/>

                <View android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/uap_divider"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"/>
                <include layout="@layout/item_profil_row"
                    android:id="@+id/rowTahunMasuk"/>

                <View android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/uap_divider"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"/>
                <include layout="@layout/item_profil_row"
                    android:id="@+id/rowStatus"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/uap_card_background"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATA PRIBADI"
                    android:textColor="@color/uap_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp"/>
                <include layout="@layout/item_profil_row"
                    android:id="@+id/rowEmail"/>

                <View android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/uap_divider"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"/>
                <include layout="@layout/item_profil_row"
                    android:id="@+id/rowNoHp"/>

                <View android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/uap_divider"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"/>
                <include layout="@layout/item_profil_row"
                    android:id="@+id/rowAlamat"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="KELUAR / LOGOUT"
            android:textColor="@color/uap_on_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"
            app:backgroundTint="@color/uap_error"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_logout"
            app:iconTint="@color/uap_on_primary"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:rippleColor="#33FFFFFF"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>

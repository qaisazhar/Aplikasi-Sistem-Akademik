<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="5dp"
    android:layout_marginBottom="5dp"
    app:cardCornerRadius="14dp"
    app:cardBackgroundColor="@color/uap_card_background"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:minWidth="52dp">

            <TextView
                android:id="@+id/tvJamMulai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="07.30"
                android:textColor="@color/uap_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"/>
            <View
                android:layout_width="1dp"
                android:layout_height="16dp"
                android:background="@color/uap_border"
                android:layout_gravity="center"/>

            <TextView
                android:id="@+id/tvJamSelesai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="09.10"
                android:textColor="@color/uap_text_hint"
                android:textSize="12sp"
                android:gravity="center"/>

        </LinearLayout>
        <View
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_line_purple"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="12dp"
            android:minHeight="60dp"/>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvNamaMatkulJadwal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mobile Programming 1"
                android:textColor="@color/uap_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/tvDosenJadwal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ratnasari, S.Kom., M.Kom"
                android:textColor="@color/uap_text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="3dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_location"
                    app:tint="@color/uap_primary"/>

                <TextView
                    android:id="@+id/tvRuanganJadwal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lab. Komputer 1"
                    android:textColor="@color/uap_text_secondary"
                    android:textSize="11sp"
                    android:layout_marginStart="4dp"/>
                <TextView
                    android:id="@+id/tvSksJadwal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 SKS"
                    android:textColor="@color/uap_primary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_badge_purple"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="5dp"
    android:layout_marginBottom="5dp"
    app:cardCornerRadius="14dp"
    app:cardBackgroundColor="@color/uap_card_background"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">
        <androidx.cardview.widget.CardView
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="22dp"
            app:cardBackgroundColor="@color/uap_surface_variant"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/ivIconPembayaran"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_payment"/>

        </androidx.cardview.widget.CardView>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">
            <TextView
                android:id="@+id/tvJenisPembayaran"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="UKT Semester 5"
                android:textColor="@color/uap_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvTanggalBayar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15 Agustus 2025"
                android:textColor="@color/uap_text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="3dp"/>
            <TextView
                android:id="@+id/tvNoTransaksi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRX-20250815-001"
                android:textColor="@color/uap_text_hint"
                android:textSize="10sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:layout_marginStart="8dp">
            <TextView
                android:id="@+id/tvNominalPembayaran"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 3.500.000"
                android:textColor="@color/uap_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvStatusPembayaran"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lunas"
                android:textColor="@color/uap_on_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_count"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>